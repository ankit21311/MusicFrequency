# Environment variables — copy this to .env and fill in your values
# NEVER commit the actual .env file — it contains your secrets

# MongoDB Atlas connection string
# Atlas Dashboard → Your Cluster → Connect → Drivers → Copy the URI
# Replace <password> with your DB user's password
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hz_music?retryWrites=true&w=majority&appName=Cluster0

# Server port — Render sets this automatically, leave it out in production
# PORT=3000

# Admin credentials validated server-side
ADMIN_USERNAME=Gauravi
ADMIN_PASSWORD=Gauravi@1234
