# Environment variables — copy this to .env and fill in your values
# NEVER commit the actual .env file

# SQLite database file path
# On Render free tier this resets on every deploy (ephemeral filesystem)
# Add a Render Persistent Disk and set DB_PATH=/var/data/hz_music.db to keep data
DB_PATH=hz_music.db

# Server port — Render sets this automatically in production
# PORT=3000

# Admin credentials (validated server-side in app.py)
ADMIN_USERNAME=Gauravi
ADMIN_PASSWORD=Gauravi@1234
